BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
ENVIRONMENT=development
LOG_LEVEL=INFO
LOG_FORMAT=json

GITHUB_TOKEN=your_github_token_here
GITHUB_WEBHOOK_SECRET=change_me

# LLM enrichment defaults to a free local Ollama model. Claude/Anthropic is optional.
LLM_PROVIDER=ollama
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-haiku-20240307

DATABASE_URL=sqlite:///./data/archaeologist.db
OLLAMA_API_URL=http://ollama:11434
LLM_MODEL=llama3:latest
QUEUE_TYPE=memory
CACHE_DIR=./data/cache
CACHE_TTL=86400
MAX_WORKERS=4
MAX_COMMIT_DEPTH=500
WEBHOOK_TIMEOUT=30
ANALYSIS_TIMEOUT=300
ENABLE_LLM_ANALYSIS=false
ENABLE_WEBHOOKS=true
ENABLE_BACKGROUND_JOBS=true

VITE_API_URL=http://localhost:8000

# OpenClaw / Telegram integration
ARCHAEOLOGIST_API_URL=http://localhost:8000
BACKEND_URL=http://localhost:8000
TELEGRAM_BOT_TOKEN=
